# ============================================================================================= #
# .gitattributes: Normalize line endings, configure diff drivers, and control GitHub behavior   #
# Documentation: https://git-scm.com/docs/gitattributes                                        #
# ============================================================================================= #

# ----- [ Global Defaults ] ------------------------------------------------------------------ #
# Enforce LF line endings across all platforms for CI consistency.
* text=auto eol=lf

# ----- [ Explicit Text Files ] -------------------------------------------------------------- #
*.md          text diff=markdown
*.yml         text diff=yaml
*.yaml        text diff=yaml
*.json        text diff=json
*.hcl         text diff=hcl
*.pkr.hcl     text diff=hcl
*.pkrvars.hcl text diff=hcl
*.pkrtpl.hcl  text diff=hcl
*.sh          text eol=lf
*.bash        text eol=lf
*.cfg         text
*.conf        text
*.txt         text
LICENSE       text
Makefile      text

# ----- [ Binary Files ] --------------------------------------------------------------------- #
*.png  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.ico  binary
*.pdf  binary

# ----- [ GitHub Linguist Overrides ] -------------------------------------------------------- #
# Mark HCL as the primary language for this repository.
*.hcl         linguist-language=HCL
*.pkr.hcl     linguist-language=HCL
*.pkrvars.hcl linguist-language=HCL
*.pkrtpl.hcl  linguist-language=HCL

# Classify non-primary content so GitHub language stats reflect actual project code.
.config/**    linguist-vendored
.github/**    linguist-documentation
.vscode/**    linguist-vendored
docs/**       linguist-documentation

# ----- [ Export Ignore ] -------------------------------------------------------------------- #
# Exclude development tooling from GitHub release archives (git archive / Download ZIP).
.config/           export-ignore
.devcontainer/     export-ignore
.editorconfig      export-ignore
.github/           export-ignore
.gitattributes     export-ignore
.pre-commit-config.yaml export-ignore
.vscode/           export-ignore
CODE_OF_CONDUCT.md export-ignore
CONTRIBUTING.md    export-ignore
SECURITY.md        export-ignore
SUPPORT.md         export-ignore
docs/              export-ignore
